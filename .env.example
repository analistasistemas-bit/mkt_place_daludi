# ── LLM ──────────────────────────────────────────────────────
LLM_PROVIDER=stub
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ── Embeddings ───────────────────────────────────────────────
EMBEDDINGS_PROVIDER=stub
